# OperAID Experiment Configuration
# Source this file before running experiments

# --- LLM Provider ---
# Supported: chutes, openrouter
# Set the corresponding API key in your environment:
#   chutes:     CHUTES_API_TOKEN
#   openrouter: OPENROUTER_API_KEY
LLM_PROVIDER="openrouter"
LLM_MODEL="z-ai/glm-5"
LLM_MAX_TURNS="3"
LLM_TEMPERATURE="0.0"
LLM_MAX_TOKENS="4096"
LLM_REQUEST_TIMEOUT="${LLM_REQUEST_TIMEOUT:-240}"

# --- Kubernetes ---
# Namespace (overridden by deployment profile if profile is set)
NAMESPACE="open5gs"

# --- Deployment Profile ---
# Path or name of the deployment profile JSON file
# Examples: "open5gs", "free5gc", "/path/to/custom-profile.json"
DEPLOYMENT_PROFILE="${DEPLOYMENT_PROFILE:-open5gs}"

# --- Paths ---
OPENVERSO_CHARTS_DIR="${OPENVERSO_CHARTS_DIR:-/home/ariel/git/openverso-charts}"

# --- Experiment ---
RUNS_PER_SCENARIO="${RUNS_PER_SCENARIO:-3}"

# --- Timeouts (seconds) ---
# Prevent commands from hanging indefinitely

# kubectl command timeout for diagnostic tools (get, describe, logs, etc.)
KUBECTL_COMMAND_TIMEOUT="${KUBECTL_COMMAND_TIMEOUT:-10}"

# Health check / verification timeout (Python script execution)
HEALTH_CHECK_TIMEOUT="${HEALTH_CHECK_TIMEOUT:-120}"

# Helm operations timeout
HELM_TIMEOUT="${HELM_TIMEOUT:-180}"

# kubectl scale timeout
KUBECTL_SCALE_TIMEOUT="${KUBECTL_SCALE_TIMEOUT:-30}"

# kubectl apply timeout
KUBECTL_APPLY_TIMEOUT="${KUBECTL_APPLY_TIMEOUT:-60}"

# kubectl delete timeout
KUBECTL_DELETE_TIMEOUT="${KUBECTL_DELETE_TIMEOUT:-30}"

# kubectl rollout restart timeout
KUBECTL_ROLLOUT_TIMEOUT="${KUBECTL_ROLLOUT_TIMEOUT:-30}"

# Remediation step timeout (max time per LLM-proposed command)
REMEDIATION_STEP_TIMEOUT="${REMEDIATION_STEP_TIMEOUT:-30}"
TRY_QUERY_AGAIN="10"
